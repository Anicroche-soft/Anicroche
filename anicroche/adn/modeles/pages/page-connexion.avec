@args [$section]

@if [$section = navigation]
    navigation
        <div .gauche>
            ancre-boite / Retour
                icone-fleche-gauche

        <div .centre>
            <span>
                "Connexion"

        <div .droite>
            ancre-boite /preferences Préférences
                icone-engrenage

@if [$section = page]
    page
        <h1>
            "Connectez-vous !"
