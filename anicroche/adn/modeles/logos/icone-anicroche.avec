@script [
    $monter_icone_anicroche = ($node) =>
    {
        const etoile = $node.querySelector('.etoile')
        const parent = $node.closest('a[href], button:not(:disabled)')

        if (!parent) return

        let en_cours = false

        const animer = () =>
        {
            if (en_cours) return

            en_cours = true
            etoile.classList.add('anime')
            etoile.addEventListener('animationend', () =>
            {
                en_cours = false
                etoile.classList.remove('anime')
            }, { once: true })
        }

        $node._avec_vars.animer = animer
        $node._avec_vars.parent = parent

        parent.addEventListener('mouseenter', animer)
        parent.addEventListener('focusin',    animer)
    }

    $demonter_icone_anicroche = ($node) =>
    {
        const { animer, parent } = $node._avec_vars

        if (!parent) return

        parent.removeEventListener('mouseenter', animer)
        parent.removeEventListener('focusin',    animer)
    }
]

@style [
    @keyframes rotation-icone-anicroche {
        from {
            transform: rotate(-72deg);
        }
        to {
            transform: rotate(0deg);
        }
    }

    .icone-anicroche {
        width: calc(var(--l-fonte) * 1.5);
        height: calc(var(--l-fonte) * 1.5);
    }

    .icone-anicroche .etoile {
        transform-origin: 50% 50%;
    }

    .icone-anicroche .etoile.anime {
        animation: rotation-icone-anicroche var(--d-animation);
    }
]

<svg .icone-anicroche
     @mount="$monter_icone_anicroche($node)"
     @unmount="$demonter_icone_anicroche($node)"
     viewBox="0 0 24 24"> 
    <path         d="M16 1H8C4.13401 1 1 4.13401 1 8V16C1 19.866 4.13401 23 8 23H16C19.866 23 23 19.866 23 16V8C23 4.13401 19.866 1 16 1Z">
    <path .etoile d="M13.9016 6.38184C13.6338 5.55802 12.8665 5.00012 12.0003 5C11.134 5.00012 10.3657 5.55802 10.0979 6.38184L9.4241 8.4541H7.24344C6.37697 8.4541 5.60883 9.01285 5.34109 9.83691C5.07353 10.6609 5.36677 11.5631 6.06765 12.0723L7.8323 13.3545L7.15847 15.4277C6.89091 16.2517 7.18418 17.1539 7.88504 17.6631C8.58598 18.1724 9.53464 18.1723 10.2356 17.6631L11.9993 16.3818L13.7639 17.6631C14.4649 18.1723 15.4136 18.1724 16.1145 17.6631C16.8154 17.1539 17.1087 16.2517 16.8411 15.4277L16.1673 13.3545L17.9319 12.0723C18.6328 11.5631 18.926 10.6609 18.6585 9.83691C18.3907 9.01285 17.6226 8.4541 16.7561 8.4541H14.5755L13.9016 6.38184Z">
