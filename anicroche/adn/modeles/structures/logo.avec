@style [

    #logo {
        --c-flux: var(--c-vif);
    }

    #logo > a {
        --l-ecart: 0.5rem;
    }

    #logo .logotype-anicroche {
        height: 1.5rem;

        --l-fonte: 1.5rem;
    }

    .petit #logo .logotype-anicroche,
    .petit.portrait #logo {
        display: none;
    }
]

<div #logo>
    ancre-boite / Anicroche
        icone-anicroche
        logotype-anicroche
