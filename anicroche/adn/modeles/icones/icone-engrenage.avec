@style [
    .icone-engrenage {
        width: calc(var(--l-fonte) * 1.5);
        height: calc(var(--l-fonte) * 1.5);
    }

    .icone-engrenage .roue {
        transform-origin: 50% 50%;
        transition: transform var(--d-animation) linear;
    }

    :is(
        a, button:not(:disabled)
    ):is(
        :hover, :focus-visible
    ) .icone-engrenage .roue {
        transform: rotate(90deg);
    }
]

