@script [
    $monter_icone_horloge = ($node, $vars) =>
    {
        const horloge = {
            aiguilles : {
                heures:  $node.querySelector('.aiguille.heures'),
                minutes: $node.querySelector('.aiguille.minutes')
            },
            nombres : [
                $node.querySelector('.nombre.xii'),
                $node.querySelector('.nombre.i'),
                $node.querySelector('.nombre.ii'),
                $node.querySelector('.nombre.iii'),
                $node.querySelector('.nombre.iv'),
                $node.querySelector('.nombre.v'),
                $node.querySelector('.nombre.vi'),
                $node.querySelector('.nombre.vii'),
                $node.querySelector('.nombre.viii'),
                $node.querySelector('.nombre.ix'),
                $node.querySelector('.nombre.x'),
                $node.querySelector('.nombre.xi')
            ]
        }

        actualiser(horloge)

        const maintenant = new Date()
        const temps_restant = (60 - maintenant.getSeconds()) * 1000 - maintenant.getMilliseconds()

        const chrono_timeout = setTimeout(() => {
            actualiser(horloge)

            const chrono_interval = setInterval(() => {
                actualiser(horloge)
            }, 3000)

            $vars.chronometre = chrono_interval
        }, temps_restant)

        $vars.chronometre = chrono_timeout
    }

    $demonter_icone_horloge = ($node, $vars) =>
    {
        if ($vars.chronometre)
        {
            clearInterval($vars.chronometre)
            $vars.chronometre = null
        }
    }

    const actualiser = (horloge) =>
    {
        const maintenant = new Date()

        const heures = maintenant.getHours()
        const minutes = maintenant.getMinutes()

        const angle_heures = (heures % 12) * 30 + minutes * 0.5
        const angle_minutes = minutes * 6

        horloge.aiguilles.heures.style.transform = `rotate(${angle_heures}deg)`
        horloge.aiguilles.minutes.style.transform = `rotate(${angle_minutes}deg)`

        for (let i in horloge.nombres)
        {
            horloge.nombres[i].classList.toggle(
                'masque',
                difference_angle(angle_heures, i * 30) < 15
             || difference_angle(angle_minutes, i * 30) < 30
            )
        }
    }

    const difference_angle = (a, b) => {
        const diff = Math.abs(a - b) % 360
        return diff > 180 ? 360 - diff : diff
    }
]

@style [
    .icone-horloge {
        width: calc(var(--l-fonte) * 1.5);
        height: calc(var(--l-fonte) * 1.5);
    }

    .icone-horloge .aiguille {
        transform-origin: 50% 50%;
    }

    .icone-horloge .nombre {
        transition: opacity var(--d-animation);
    }

    .icone-horloge .nombre.masque {
        opacity: 0;
    }
]

<svg
    .icone-horloge
    @mount="$monter_icone_horloge($node, $vars)"
    @unmount="$demonter_icone_horloge($node, $vars)"
    viewBox="0 0 24 24"
>
    <path                    d="M1 16V8C1 4.13401 4.13401 1 8 1H16C19.866 1 23 4.13401 23 8V16C23 19.866 19.866 23 16 23H8C4.13401 23 1 19.866 1 16Z">
    <path                    d="M12 14C13.1046 14 14 13.1046 14 12C14 10.8954 13.1046 10 12 10C10.8954 10 10 10.8954 10 12C10 13.1046 10.8954 14 12 14Z">

    <path .aiguille .heures  d="M12 10V7">
    <path .aiguille .minutes d="M12 10V5">

    <path .nombre   .i       d="M16.5007 4.20324L18.1549 1.33795">
    <path .nombre   .ii      d="M19.7967 7.49568L22.661 5.84198">
    <path .nombre   .iii     d="M23 12H21">
    <path .nombre   .iv      d="M19.8017 16.4957L22.6642 18.1483">
    <path .nombre   .v       d="M16.5093 19.7917L18.1647 22.6589">
    <path .nombre   .vi      d="M12 23V21">
    <path .nombre   .vii     d="M7.50068 19.7917L5.84375 22.6616">
    <path .nombre   .viii    d="M4.20829 16.4957L1.3374 18.1532">
    <path .nombre   .ix      d="M1 12H3">
    <path .nombre   .x       d="M4.21328 7.49567L1.34055 5.8371">
    <path .nombre   .xi      d="M7.50934 4.20327L5.8535 1.33527">
    <path .nombre   .xii     d="M12 1V3">

